# ---- Database ----
# Async driver URLs. Dev default is SQLite; prod uses Postgres.
#   dev :  sqlite+aiosqlite:///./upstream.db
#   prod:  postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./upstream.db

# ---- Auth (JWT in httpOnly cookies) ----
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# ---- Cookies ----
# Dev (same machine):   COOKIE_SECURE=false, COOKIE_SAMESITE=lax, COOKIE_DOMAIN blank
# Prod (split origin):  COOKIE_SECURE=true,  COOKIE_SAMESITE=none, COOKIE_DOMAIN=.yourdomain.com
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ---- CORS ----
# Comma-separated list of allowed frontend origins (explicit; never "*" with credentials).
CORS_ORIGINS=http://localhost:3000
